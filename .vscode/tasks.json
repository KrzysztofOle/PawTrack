{
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}",
    "env": {
      "ZEPHYR_BASE": "/Volumes/Extra/zephyrproject/zephyr",
      "ZEPHYR_TOOLCHAIN_VARIANT": "zephyr",
      "ZEPHYR_SDK_INSTALL_DIR": "/Volumes/Extra/zephyr-sdk-0.17.4",
      "PATH": "/Volumes/Extra/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin:${env:HOME}/zephyr_venv/bin:${env:PATH}"
    }
  },
  "tasks": [
    {
      "label": "Zephyr: Build (west)",
      "type": "shell",
      "command": "west",
      "args": [
        "build",
        "-d",
        "${workspaceFolder}/build",
        "-b",
        "xiao_mg24",
        "-p",
        "auto",
        "${workspaceFolder}",
        "--",
        "-DPython3_EXECUTABLE=${env:HOME}/zephyr_venv/bin/python3",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Zephyr: Rebuild Pristine (west)",
      "type": "shell",
      "command": "west",
      "args": [
        "build",
        "-d",
        "${workspaceFolder}/build",
        "-b",
        "xiao_mg24",
        "-p",
        "always",
        "${workspaceFolder}",
        "--",
        "-DPython3_EXECUTABLE=${env:HOME}/zephyr_venv/bin/python3",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Zephyr: Flash (auto runner)",
      "type": "shell",
      "command": "west",
      "args": [
        "flash",
        "--build-dir",
        "${workspaceFolder}/build",
        "--skip-rebuild"
      ],
      "problemMatcher": [],
      "dependsOn": "Zephyr: Build (west)"
    },
    {
      "label": "Zephyr: Flash (jlink)",
      "type": "shell",
      "command": "west",
      "args": [
        "flash",
        "--build-dir",
        "${workspaceFolder}/build",
        "--runner",
        "jlink",
        "--skip-rebuild"
      ],
      "problemMatcher": [],
      "dependsOn": "Zephyr: Build (west)"
    },
    {
      "label": "Zephyr: Flash (pyocd)",
      "type": "shell",
      "command": "west",
      "args": [
        "flash",
        "--build-dir",
        "${workspaceFolder}/build",
        "--runner",
        "pyocd",
        "--skip-rebuild"
      ],
      "problemMatcher": [],
      "dependsOn": "Zephyr: Build (west)"
    }
  ]
}
