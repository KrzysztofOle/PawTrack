{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Zephyr: Configure (xiao_mg24)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build",
        "-GNinja",
        "-DBOARD=xiao_mg24",
        "-DWEST_PYTHON=${env:HOME}/zephyr_venv/bin/python3",
        "-DPython3_EXECUTABLE=${env:HOME}/zephyr_venv/bin/python3",
        "-DZEPHYR_BASE=/Volumes/Extra/zephyrproject/zephyr",
        "-DZEPHYR_TOOLCHAIN_VARIANT=zephyr",
        "-DZEPHYR_SDK_INSTALL_DIR=/Volumes/Extra/zephyr-sdk-0.17.4",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "options": {
        "env": {
          "ZEPHYR_BASE": "/Volumes/Extra/zephyrproject/zephyr",
          "WEST_CONFIG_LOCAL": "/Volumes/Extra/zephyrproject/.west/config",
          "ZEPHYR_TOOLCHAIN_VARIANT": "zephyr",
          "ZEPHYR_SDK_INSTALL_DIR": "/Volumes/Extra/zephyr-sdk-0.17.4",
          "PATH": "/Volumes/Extra/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin:${env:HOME}/zephyr_venv/bin:${env:PATH}"
        }
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Zephyr: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build"
      ],
      "options": {
        "env": {
          "ZEPHYR_BASE": "/Volumes/Extra/zephyrproject/zephyr",
          "WEST_CONFIG_LOCAL": "/Volumes/Extra/zephyrproject/.west/config",
          "ZEPHYR_TOOLCHAIN_VARIANT": "zephyr",
          "ZEPHYR_SDK_INSTALL_DIR": "/Volumes/Extra/zephyr-sdk-0.17.4",
          "PATH": "/Volumes/Extra/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin:${env:HOME}/zephyr_venv/bin:${env:PATH}"
        }
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": "Zephyr: Configure (xiao_mg24)",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
